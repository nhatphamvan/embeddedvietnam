wp-content/plugins/*
!wp-content/plugins/ele-custom-skin/

# Themes: chỉ track child theme tự viết
wp-content/themes/*
!wp-content/themes/oceanwp-child/

# Database - KHÔNG commit
*.sql

# Local environment secrets
.env

# WordPress core files lẻ
xmlrpc.php
license.txt
readme.html
.htaccess.bk

# Runtime data (thay đổi liên tục, không cần track)
storage/

# Deploy script — upload thủ công lên server, không commit
deploy.php
deploy.log

