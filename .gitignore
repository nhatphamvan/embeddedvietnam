# WordPress core
/wp-admin/
/wp-includes/
/wp-*.php
!/wp-config-sample.php
/index.php

# Config chứa password - KHÔNG BAO GIỜ commit
wp-config.php
wp-config

# Uploads, cache, backup
wp-content/uploads/
wp-content/cache/
wp-content/litespeed/
wp-content/ai1wm-backups/
wp-content/upgrade/

